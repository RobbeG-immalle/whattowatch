generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String          @id @default(cuid())
  name           String?
  email          String?         @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  credits        Int             @default(3)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  accounts       Account[]
  sessions       Session[]
  searches       Search[]
  watchlist      WatchlistItem[]
  purchases      Purchase[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Search {
  id        String   @id @default(cuid())
  userId    String
  prompt    String
  results   Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WatchlistItem {
  id         String          @id @default(cuid())
  userId     String
  tmdbId     Int
  title      String
  posterPath String?
  overview   String?
  rating     Float?
  genres     Json?
  status     WatchlistStatus @default(WANT_TO_WATCH)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tmdbId])
}

enum WatchlistStatus {
  WANT_TO_WATCH
  WATCHED
}

model Purchase {
  id              String         @id @default(cuid())
  userId          String
  credits         Int
  amount          Int
  stripeSessionId String?        @unique
  status          PurchaseStatus @default(PENDING)
  createdAt       DateTime       @default(now())
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  FAILED
}
