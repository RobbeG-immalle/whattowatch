# Database
# For Supabase: set DATABASE_URL to the connection pooler URL (port 6543) for runtime queries
# and DIRECT_URL to the direct connection URL (port 5432) for prisma db push / migrations.
# For Neon or self-hosted Postgres: set both variables to the same connection string.
DATABASE_URL="postgresql://user:password@localhost:5432/whattowatch"
DIRECT_URL="postgresql://user:password@localhost:5432/whattowatch"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"

# OAuth Providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_ID=""
GITHUB_SECRET=""

# OpenAI
OPENAI_API_KEY=""

# TMDB
TMDB_API_KEY=""
TMDB_BASE_URL="https://api.themoviedb.org/3"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
